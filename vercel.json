{
  "version": 2,
  "name": "buildr",
  "alias": "buildr-ej83inn72-sarangs-projects-8b8ce6ab.vercel.app",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
